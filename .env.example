# ReRide Environment Variables
# Copy this file to .env and fill in your actual values

# MongoDB Configuration
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/reride?retryWrites=true&w=majority
# For Local MongoDB: mongodb://localhost:27017/reride?retryWrites=true&w=majority
MONGODB_URL=mongodb://localhost:27017/reride?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/reride?retryWrites=true&w=majority

# Google Gemini AI (Optional - for AI features)
GEMINI_API_KEY=your_gemini_api_key_here

# Firebase Configuration (Optional - for image uploads and auth)
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Supabase Configuration (for auth, DB, real-time)
# Get from: Dashboard → Project Settings → API (or use Supabase MCP in Cursor)
# --- Client (browser): required for app. Use VITE_ prefix so Vite injects them. ---
#
# Environment split (Vite):
#   • Production mobile / web release: use .env.production with LIVE Supabase project URL + anon key.
#   • Local PC + emulator testing: use .env.development (or .env.local) with a dev/staging Supabase project
#     OR the same live project — then run `npm run build:android:dev` so MODE=development loads those vars.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
# Google sign-in: Supabase Dashboard → Authentication → Providers → Google (enable + Web client ID/secret).
# URL Configuration → Redirect URLs must include your app origins, e.g. https://www.reride.co.in/** ,
# https://appassets.androidplatform.net/** , http://localhost:5173/** ,
# com.reride.app://oauth-callback (Android Google OAuth PKCE return — required for Custom Tab flow)
#
# --- Server (API / Vercel): required for /api/* routes and admin operations. ---
# On Vercel, you can set only the VITE_* vars above and they are available to both client and server.
# Optionally set these for server-only usage (e.g. local dev API or non-Vite server):
# SUPABASE_URL=https://your-project-ref.supabase.co
# SUPABASE_ANON_KEY=your_supabase_anon_key
# Required in production (Vercel): admin panel and API need this. Set in Vercel → Project → Settings → Environment Variables for Production, then redeploy.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# --- Production (Vercel): used-cars / vehicles will show "Unable to load vehicles" until these are set ---
# In Vercel: Settings → Environment Variables → add for "Production":
#   SUPABASE_URL = same as VITE_SUPABASE_URL (https://xxxx.supabase.co)
#   SUPABASE_SERVICE_ROLE_KEY = from Supabase Dashboard → Project Settings → API → service_role (secret)
# Then redeploy. Without these, /api/vehicles returns 503 and no vehicles load.
#
# --- Prevent 500 FUNCTION_INVOCATION_FAILED (required for API to load) ---
# Set in Vercel → Environment Variables → Production:
#   JWT_SECRET = a long random string (e.g. 32+ chars). Used for auth tokens.
# If missing, the serverless function crashes on load and all /api/* return 500.

# Cloudinary Configuration (Optional - alternative to Firebase for image uploads)
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=your_upload_preset

# Force API Mode (Set to 'true' to always use API, even in development)
VITE_FORCE_API=false

# Vehicle listing (web browser): fetch published inventory in chunks then merge (smaller JSON per request).
# Optional page size 20–200 (default 80). Set VITE_VEHICLES_LEGACY_FULL_FETCH=true only if you need the old single request (?limit=0).
# VITE_VEHICLES_PAGE_SIZE=80
# VITE_VEHICLES_LEGACY_FULL_FETCH=false

# API Base URL (Capacitor / mobile)
# ─ Production Play Store / App Store build: leave unset → app uses https://www.reride.co.in (apex → www is normalized in code).
# ─ Local PC backend: either set explicitly OR use bundled local defaults (development mode only):
#     1) npm run dev:api   (Node API on port 3001 by default)
#     2) .env.development: VITE_MOBILE_LOCAL_DEV=true
#     3) npm run build:android:dev   (MODE=development → loads .env.development Supabase + local API host)
# Optional: VITE_LOCAL_API_PORT=3001 if your dev API uses another port.
# Override host any time: VITE_API_URL=http://YOUR_LAN_IP:3001 (physical device on Wi‑Fi)
# Android emulator + explicit URL: VITE_API_URL=http://10.0.2.2:3001 (localhost/127.0.0.1 auto-rewrite on Android)
#
# After changing env or android/MainActivity (mixed HTTP API + HTTPS WebView), run: npx cap sync android
# VITE_MOBILE_LOCAL_DEV=true
# VITE_API_URL=https://www.reride.co.in
# Optional: second API origin for Capacitor / appassets WebView retries if primary fails (e.g. DNS).
# VITE_API_FALLBACK_URL=https://reride-app.vercel.app

# Node Environment
NODE_ENV=development

# --- Optional: Production hardening ---
# SEO / Canonical URL (used in sitemap and meta tags)
# VITE_APP_URL=https://www.reride.co.in

# Google Analytics 4 (optional - set to enable page and event tracking)
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Sentry error monitoring (optional - set to enable error tracking in production)
# VITE_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# Email (Resend) - for verification, password reset, inquiry notifications
# RESEND_API_KEY=re_xxxx
# FROM_EMAIL=ReRide <noreply@reride.co.in>

# Rate limiting with Upstash Redis (optional - when set, replaces in-memory rate limit for serverless)
# UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=xxx

# --- Phone OTP via MessageBot (India SMS) — optional alternative to Supabase/Twilio SMS ---
# Client: set VITE_OTP_SMS_PROVIDER=messagebot so "Phone OTP" uses the server actions below.
# VITE_OTP_SMS_PROVIDER=messagebot
#
# Server (Vercel / dev-api-server): MessageBot SendSmsV2 — https://messagebot.in/docs
# MESSAGEBOT_API_TOKEN=your_api_token
# MESSAGEBOT_SENDER_ID=YOURDLT  # approved 6-char sender ID
# Optional: India DLT (required for production OTP on most networks)
# MESSAGEBOT_DLT_ENTITY_ID=your_entity_id
# MESSAGEBOT_DLT_TEMPLATE_ID=your_template_id
# Must match the registered DLT template text (use {otp} where the code goes):
# MESSAGEBOT_OTP_MESSAGE_TEMPLATE=Your ReRide OTP is {otp}. Valid for 10 minutes. Do not share with anyone.
# MESSAGEBOT_API_URL=https://papi.messagebot.in/SendSmsV2
#
# Supabase: table `otp_verifications` with columns phone (unique), otp_hash, expires_at, created_at — used to verify codes.
# JWT_SECRET must be set (same as rest of API) for hashing OTPs at rest.
