# ReRide Environment Variables
# Copy this file to .env and fill in your actual values

# MongoDB Configuration
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/reride?retryWrites=true&w=majority
# For Local MongoDB: mongodb://localhost:27017/reride?retryWrites=true&w=majority
MONGODB_URL=mongodb://localhost:27017/reride?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/reride?retryWrites=true&w=majority

# Google Gemini AI (Optional - for AI features)
GEMINI_API_KEY=your_gemini_api_key_here

# Firebase Configuration (Optional - for image uploads and auth)
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Supabase Configuration (for auth, DB, real-time)
# Get from: Dashboard → Project Settings → API (or use Supabase MCP in Cursor)
# --- Client (browser): required for app. Use VITE_ prefix so Vite injects them. ---
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
# --- Server (API / Vercel): required for /api/* routes and admin operations. ---
# On Vercel, you can set only the VITE_* vars above and they are available to both client and server.
# Optionally set these for server-only usage (e.g. local dev API or non-Vite server):
# SUPABASE_URL=https://your-project-ref.supabase.co
# SUPABASE_ANON_KEY=your_supabase_anon_key
# Required in production (Vercel): admin panel and API need this. Set in Vercel → Project → Settings → Environment Variables for Production, then redeploy.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# --- Production (Vercel): used-cars / vehicles will show "Unable to load vehicles" until these are set ---
# In Vercel: Settings → Environment Variables → add for "Production":
#   SUPABASE_URL = same as VITE_SUPABASE_URL (https://xxxx.supabase.co)
#   SUPABASE_SERVICE_ROLE_KEY = from Supabase Dashboard → Project Settings → API → service_role (secret)
# Then redeploy. Without these, /api/vehicles returns 503 and no vehicles load.
#
# --- Prevent 500 FUNCTION_INVOCATION_FAILED (required for API to load) ---
# Set in Vercel → Environment Variables → Production:
#   JWT_SECRET = a long random string (e.g. 32+ chars). Used for auth tokens.
# If missing, the serverless function crashes on load and all /api/* return 500.

# Cloudinary Configuration (Optional - alternative to Firebase for image uploads)
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=your_upload_preset

# Force API Mode (Set to 'true' to always use API, even in development)
VITE_FORCE_API=false

# Node Environment
NODE_ENV=development
