<?xml version="1.0" encoding="utf-8"?>
<!--
  Production: block cleartext HTTP (MITM risk).
  Debug builds: allow cleartext for Capacitor live reload (http://10.0.2.2:5173) and local API.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
    <debug-overrides cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </debug-overrides>
</network-security-config>
