# Copy to android/keystore.properties (gitignored) and fill in your upload keystore.
# Paths are relative to the android/ folder.
#
# Current upload key: app/reride-newrelease (PKCS12, alias reride-newrelease).
# Do NOT use app/reride-release-key.jks unless you know its password and alias.
#
# Verify before a Play upload:
#   cd android && gradlew.bat :app:signingReport
# Release AAB (uses this file automatically):
#   npm run android:aab

storeFile=app/reride-newrelease
storeType=PKCS12
storePassword=YOUR_KEYSTORE_PASSWORD
keyAlias=reride-newrelease
keyPassword=YOUR_KEY_PASSWORD
